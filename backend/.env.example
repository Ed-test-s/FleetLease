# -----------------------------------------------------------------------------
# Local development (docker-compose)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://fleetlease:fleetlease_secret@localhost:5432/fleetlease
DATABASE_URL_SYNC=postgresql://fleetlease:fleetlease_secret@localhost:5432/fleetlease
SECRET_KEY=change-me-to-a-random-secret-key
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=fleetlease
MINIO_ABOUT_BUCKET=about-site
MINIO_SECURE=false
MINIO_EXTERNAL_ENDPOINT=localhost:9000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5173

NBRB_BASE_URL=https://api.nbrb.by
NBRB_REQUEST_TIMEOUT=15
VAT_RATE_PERCENT=20

# Почта (восстановление пароля). Без MAIL_SERVER отправка писем отключена.
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@mail.com
MAIL_PASSWORD=aaaaaaaaaaaaaaaa
MAIL_FROM=your-email@gmail.com
MAIL_FROM_NAME=your_company_name
MAIL_STARTTLS=true
MAIL_SSL_TLS=false

# -----------------------------------------------------------------------------
# Railway production example (set in Railway Variables UI)
# -----------------------------------------------------------------------------
# DATABASE_URL=postgresql+asyncpg://<user>:<password>@<host>:<port>/<db>
# DATABASE_URL_SYNC=postgresql://<user>:<password>@<host>:<port>/<db>
# SECRET_KEY=<random-long-secret>
# MINIO_ENDPOINT=<private-s3-endpoint>:443
# MINIO_ACCESS_KEY=<railway-object-storage-access-key>
# MINIO_SECRET_KEY=<railway-object-storage-secret-key>
# MINIO_BUCKET=<your-bucket-name>
# MINIO_ABOUT_BUCKET=<your-about-bucket-name>
# MINIO_SECURE=true
# MINIO_EXTERNAL_ENDPOINT=https://<public-s3-endpoint>
# CORS_ORIGINS=["https://<frontend-domain>.up.railway.app"]
